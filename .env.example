# ============================================================
# Hayonero2 - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it is listed in .gitignore.

# ------------------------------------------------------------
# Discord
# ------------------------------------------------------------

# Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Application Client ID
CLIENT_ID=your_client_id_here

# Optional: Guild ID for dev-only command registration (leave empty for global)
GUILD_ID=

# ------------------------------------------------------------
# Encryption  (CRITICAL — keep these values secret)
# ------------------------------------------------------------

# Master secret for AES-256-GCM encryption of guild settings.
# Minimum 32 chars; use a cryptographically random value.
# Generate with: openssl rand -base64 48
ENCRYPTION_SECRET=replace_this_with_a_long_random_secret_at_least_32_chars

# Key version for rotation (default: 1, increment when rotating keys).
# When rotating, archive the old secret as ENCRYPTION_SECRET_V<n>.
ENCRYPTION_KEY_VERSION=1

# Archived secrets for key rotation (required when ENCRYPTION_KEY_VERSION > 1).
# Example: if rotating from v1 to v2, set:
#   ENCRYPTION_SECRET_V1=<old ENCRYPTION_SECRET value>
# ENCRYPTION_SECRET_V1=

# ------------------------------------------------------------
# Database (Prisma — only needed for feature/prisma-multi-db)
# ------------------------------------------------------------

# SQLite (default):
DATABASE_URL=file:./data/hayonero2.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/hayonero2?schema=public

# MySQL / MariaDB example:
# DATABASE_URL=mysql://user:password@localhost:3306/hayonero2

# ------------------------------------------------------------
# Backup
# ------------------------------------------------------------

# Directory to store backup files (default: data/backups)
# BACKUP_DIR=data/backups

# Number of days to retain backups (default: 7)
# BACKUP_RETENTION_DAYS=7

# Cron expression for automatic backups (default: 3:00 AM daily)
# BACKUP_SCHEDULE=0 3 * * *

# ------------------------------------------------------------
# Monitoring / Alerting
# ------------------------------------------------------------

# Discord webhook URL for critical alerts (backup failures, DB errors).
# Create via: Server Settings → Integrations → Webhooks
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
