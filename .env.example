# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Encryption master secret (min 32 chars, keep this SECRET - never commit to git)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ENCRYPTION_SECRET=your_very_long_random_secret_at_least_64_chars_here_change_this

# Guild ID for dev-only registration (optional - leave empty for global)
GUILD_ID=
